@model minipokedex.Models.Pokemon.PokemonDetailViewModel

@{
    ViewData["Title"] = $"Detalle - {Model.Name}";

    var statsOrder = new (string Key, string Label)[]
    {
        ("hp", "HP"),
        ("attack", "Attack"),
        ("defense", "Defense"),
        ("special-attack", "Sp. Atk"),
        ("special-defense", "Sp. Def"),
        ("speed", "Speed")
    };

    var statsByName = Model.BaseStats
        .ToDictionary(
            item => item.Name,
            item => item.Value,
            StringComparer.OrdinalIgnoreCase);

    var totalStats = statsByName.Values.Sum();
    var hasShiny = !string.IsNullOrWhiteSpace(Model.ShinySpriteUrl);
    var spriteToRender = Model.SpriteUrl;
}

<a class="btn btn-outline-secondary btn-sm mb-4" asp-controller="Pokemon" asp-action="Index">← Volver al Pokédex</a>

<div class="pokemon-detail-page">
    <div class="pokemon-detail-header">
        <p class="pokemon-detail-id mb-1">#@Model.Id.ToString("D3")</p>
        <h1 class="pokemon-detail-name text-capitalize mb-3">@Model.Name</h1>
        <div class="d-flex flex-wrap gap-2">
            @foreach (var type in Model.Types)
            {
                <span class="pokemon-type-badge pokemon-type-@type.ToLowerInvariant() text-capitalize">@type</span>
            }
        </div>
    </div>

    <div class="pokemon-detail-content mt-3">
        <section>
            <div class="pokemon-detail-image-wrapper">
                <img id="pokemonSprite" src="@spriteToRender" data-mode="default" data-default-src="@Model.SpriteUrl" data-shiny-src="@Model.ShinySpriteUrl" alt="@Model.Name" class="pokemon-detail-image" />
            </div>

            @if (hasShiny)
            {
                <div class="mt-3">
                    <button type="button" id="toggleShinyButton" class="btn btn-outline-warning btn-sm">✨ Ver versión shiny</button>
                </div>
            }

            <dl class="pokemon-detail-metrics">
                <div><dt>Altura</dt><dd>@((Model.Height / 10.0M).ToString("0.0")) m</dd></div>
                <div><dt>Peso</dt><dd>@((Model.Weight / 10.0M).ToString("0.0")) kg</dd></div>
                <div><dt>XP base</dt><dd>@Model.BaseExperience</dd></div>
            </dl>

            <div>
                <h2 class="pokemon-detail-section-title">Habilidades</h2>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var ability in Model.Abilities)
                    {
                        <span class="badge rounded-pill @(ability.IsHidden ? "text-bg-secondary" : "text-bg-primary") text-capitalize">
                            @ability.Name@(ability.IsHidden ? " (Oculta)" : string.Empty)
                        </span>
                    }
                </div>
            </div>
        </section>

        <section>
            <h2 class="pokemon-detail-section-title mb-3">Estadísticas base</h2>

            @foreach (var stat in statsOrder)
            {
                var value = statsByName.TryGetValue(stat.Key, out var currentValue) ? currentValue : 0;
                var width = Math.Clamp((value / 255.0M) * 100.0M, 0, 100);
                var barClass = value < 60 ? "is-low" : "is-mid";

                <div class="pokemon-stat-row">
                    <div class="pokemon-stat-name">@stat.Label</div>
                    <div class="pokemon-stat-value">@value</div>
                    <div class="pokemon-stat-track" role="img" aria-label="@stat.Label @value">
                        <span class="pokemon-stat-fill @barClass" style="width: @width.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></span>
                    </div>
                </div>
            }

            <div class="pokemon-stat-total mt-3 pt-2">
                <span>Total</span>
                <span>@totalStats</span>
            </div>
        </section>
    </div>
</div>

@if (hasShiny)
{
    <script>
        (() => {
            const button = document.getElementById('toggleShinyButton');
            const sprite = document.getElementById('pokemonSprite');

            if (!button || !sprite) {
                return;
            }

            button.addEventListener('click', () => {
                const defaultSrc = sprite.dataset.defaultSrc;
                const shinySrc = sprite.dataset.shinySrc;

                if (!defaultSrc || !shinySrc) {
                    return;
                }

                const isShowingShiny = sprite.dataset.mode === 'shiny';
                sprite.src = isShowingShiny ? defaultSrc : shinySrc;
                sprite.dataset.mode = isShowingShiny ? 'default' : 'shiny';
                button.textContent = isShowingShiny ? '✨ Ver versión shiny' : '↩ Ver versión normal';
            });
        })();
    </script>
}
