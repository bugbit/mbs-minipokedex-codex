@model minipokedex.Models.Pokemon.PokemonDetailViewModel

@{
    ViewData["Title"] = $"Detalle - {Model.Name}";
}

<a class="btn btn-link px-0 mb-3" asp-controller="Pokemon" asp-action="Index">← Volver</a>

<div class="card shadow-sm">
    <div class="row g-0">
        <div class="col-md-4 d-flex align-items-center justify-content-center p-3">
            <img src="@Model.SpriteUrl" alt="@Model.Name" style="max-height: 240px; object-fit: contain;" />
        </div>
        <div class="col-md-8">
            <div class="card-body">
                <h1 class="h3 text-capitalize">@Model.Name</h1>
                <p class="text-muted">#@Model.Id</p>
                <ul class="list-unstyled mb-3">
                    <li><strong>Altura:</strong> @Model.Height</li>
                    <li><strong>Peso:</strong> @Model.Weight</li>
                </ul>
                <div>
                    @foreach (var type in Model.Types)
                    {
                        <span class="badge text-bg-primary me-1 text-capitalize">@type</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
